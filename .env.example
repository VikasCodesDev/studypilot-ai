DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"
MONGODB_URI="mongodb+srv://USER:PASSWORD@HOST/studypilot"
MONGODB_DB="studypilot"
GROQ_API_KEY="gsk_..."
GOOGLE_GEMINI_API_KEY="..."
# Required for large PDF uploads (10MB-100MB). Create a Blob store in the
# Vercel dashboard (Storage -> Blob) and copy its read/write token, or run
# `vercel blob store add` / `vercel env pull` locally.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."
